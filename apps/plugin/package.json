{
  "name": "@chartroom/plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "chartroom": "dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": ["dist", "skills"],
  "scripts": {
    "build": "tsup src/server.ts --format esm --dts --tsconfig tsconfig.build.json",
    "generate-skill": "bun scripts/generate-skill.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "bun src/server.ts",
    "build:bundle": "bun run --cwd ../../packages/renderer build:bundle"
  },
  "dependencies": {
    "@chartroom/core": "workspace:*",
    "@chartroom/renderer": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
