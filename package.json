{
  "name": "firechart",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun --filter @firechart/web dev",
    "build": "bun --filter @firechart/web build",
    "lint": "bun --filter @firechart/web lint",
    "test": "bun --filter '*' test",
    "eval": "bun --filter @firechart/eval eval"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
