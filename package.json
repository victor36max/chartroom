{
  "name": "firechart",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "bun run --filter @firechart/web dev",
    "build": "bun run --filter @firechart/web build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "eval": "bun run --filter @firechart/eval eval"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
