{
  "name": "@chartroom/renderer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src/bundle/renderer.js", "src/renderer-page.html"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "build:bundle": "bun src/build-bundle.ts",
    "prepublishOnly": "bun run build:bundle && bun run build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chartroom/core": "workspace:*",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "vega-embed": "^7.1.0",
    "typescript": "^5"
  }
}
