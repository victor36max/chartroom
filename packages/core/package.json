    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true }
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "vitest": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "^5"
  }
}
